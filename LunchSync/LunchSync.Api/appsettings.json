{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=placeholder_db;Username=placeholder;Password=placeholder",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "AppSettings": {
    "ClientBaseUrl": "http://localhost:5173/join"
  },
  "AWS": {
    "Region": "ap-southeast-1"
  },
  "Cognito": {
    "Issuer": "REPLACE_ME",
    "ClientId": "REPLACE_ME",
    "ClientSecret": "REPLACE_ME",
    "AuthFlow": "USER_PASSWORD_AUTH",
    "TokenUse": "id"
  },
  "GuestTokens": {
    "Issuer": "LunchSync.Api",
    "Audience": "LunchSync.Guests",
    "SigningKey": "replace-this-with-a-long-random-secret-at-least-32-chars",
    "ExpiryMinutes": 240
  },
  "AuthTesting": {
    "EnableDirectCognitoBearer": false
  }
}
